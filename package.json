{
    "name": "@andrew-codes/ps5-mqtt",
    "version": "0.1.4",
    "author": {
        "name": "Andrew Smith",
        "url": "https://andrew.codes"
    },
    "workspaces": [
        "ps5-mqtt/dev-services",
        "ps5-mqtt/server",
        "ps5-mqtt/client"
    ],
    "private": true,
    "engines": {
        "node": "24.16.0"
    },
    "scripts": {
        "build": "yarn workspaces foreach -A run build",
        "bump-version": "tsx scripts/bump-version.ts",
        "clean": "yarn workspaces foreach -A run clean",
        "format": "prettier --write .",
        "format/check": "prettier --check .",
        "lint": "eslint .",
        "start": "bash scripts/start.sh",
        "test/unit": "yarn workspaces foreach -A run test/unit",
        "typecheck": "tsc -p tsconfig.json && yarn workspaces foreach -A run typecheck",
        "update-changelog": "tsx scripts/update-changelog.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.13.2",
        "@types/semver": "^7.7.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.6.0",
        "prettier": "^3.8.4",
        "rimraf": "^6.1.3",
        "semver": "^7.8.5",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "packageManager": "yarn@4.16.0"
}
