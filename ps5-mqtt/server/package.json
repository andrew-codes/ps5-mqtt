{
  "name": "@andrew-codes/ps5-mqtt-server",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "rspack build --mode production",
    "clean": "rimraf dist .ts-build .packaged coverage -g '*.tsbuildinfo'",
    "package": "tsx scripts/package.ts",
    "publish": "tsx scripts/publish.ts",
    "start": "MQTT_HOST=localhost MQTT_PORT=1883 concurrently -n rspack,app -c blue,green \"rspack build --mode development --watch\" \"nodemon\"",
    "test/unit": "jest",
    "typecheck": "tsc --noEmit -p ./tsconfig.build.json && tsc --noEmit -p ./tsconfig.test.json && tsc --noEmit -p ./tsconfig.scripts.json && tsc --noEmit -p ./tsconfig.config.json"
  },
  "author": {
    "name": "Andrew Smith",
    "url": "https://andrew.codes"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "async-mqtt": "^2.6.3",
    "body-parser": "^1.20.1",
    "debug": "^4.3.4",
    "express": "^4.18.1",
    "lodash": "^4.17.21",
    "mqtt": "^4.3.7",
    "node-fetch": "^2.6.7",
    "playactor": "^0.4.1",
    "psn-api": "^2.8.2",
    "redux": "^4.2.0",
    "redux-saga": "^1.2.2",
    "shelljs": "^0.8.5"
  },
  "devDependencies": {
    "@jest/globals": "29.3.1",
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@types/debug": "^4.1.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.2.2",
    "@types/lodash": "^4.17.7",
    "@types/node": "^18.11.13",
    "@types/node-fetch": "^2.6.2",
    "@types/shelljs": "^0.8.11",
    "concurrently": "^9.1.0",
    "dotenv": "^16.0.3",
    "jest": "^29.3.0",
    "jest-util": "^29.7.0",
    "nodemon": "^3.1.7",
    "redux-saga-testing": "^2.0.2",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.0.3",
    "tslib": "^2.6.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
