{
  "name": "@andrew-codes/ps5-mqtt-server",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "rspack build --mode production",
    "clean": "rimraf dist .ts-build .packaged coverage -g '*.tsbuildinfo'",
    "package": "tsx scripts/package.ts",
    "publish": "tsx scripts/publish.ts",
    "start": "MQTT_HOST=localhost MQTT_PORT=1883 concurrently -n rspack,app -c blue,green \"rspack build --mode development --watch\" \"nodemon\"",
    "test/unit": "jest",
    "typecheck": "tsc --noEmit -p ./tsconfig.build.json && tsc --noEmit -p ./tsconfig.test.json && tsc --noEmit -p ./tsconfig.scripts.json && tsc --noEmit -p ./tsconfig.config.json"
  },
  "author": {
    "name": "Andrew Smith",
    "url": "https://andrew.codes"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "async-mqtt": "^2.6.3",
    "body-parser": "^2.3.0",
    "debug": "^4.4.3",
    "express": "^4.22.2",
    "lodash": "^4.18.1",
    "mqtt": "^5.15.1",
    "playactor": "^0.4.1",
    "psn-api": "^2.18.0",
    "redux": "^5.0.1",
    "redux-saga": "^1.5.0",
    "shelljs": "^0.10.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@types/debug": "^4.1.13",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.2",
    "@types/shelljs": "^0.10.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "jest-util": "^30.4.1",
    "nodemon": "^3.1.14",
    "redux-saga-testing": "^2.0.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
