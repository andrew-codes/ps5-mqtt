{
  "name": "@andrew-codes/ps5-mqtt-client",
  "author": {
    "name": "Andrew Smith",
    "url": "https://andrew.codes"
  },
  "version": "0.0.0",
  "scripts": {
    "build": "rspack build --mode production",
    "clean": "rimraf dist -g '*.tsbuildinfo'",
    "start": "rspack serve --mode development",
    "test/unit": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit -p ./tsconfig.build.json && tsc --noEmit -p ./tsconfig.config.json",
    "watch": "rspack build --mode development --watch"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@rspack/dev-server": "^2.0.3",
    "@rspack/plugin-react-refresh": "^2.0.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.0.11",
    "grommet": "^2.39.0",
    "grommet-icons": "^4.8.0",
    "jest": "^29.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-is": "^18.2.0",
    "react-refresh": "^0.18.0",
    "rimraf": "^5.0.10",
    "styled-components": "^5.3.6",
    "typescript": "^6.0.3"
  }
}
